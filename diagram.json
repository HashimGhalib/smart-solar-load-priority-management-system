{
  "version": 1,
  "author": "Smart Solar Priority System",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": -40.0, "left": 0.0 },
    { "type": "wokwi-lcd1602", "id": "lcd", "top": -220.0, "left": -20.0, "attrs": { "pins": "i2c" } },
    { "type": "wokwi-potentiometer", "id": "pot_batt", "top": 250.0, "left": -120.0, "attrs": { "label": "Battery Volts" } },
