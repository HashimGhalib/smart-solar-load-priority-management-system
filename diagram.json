  "connections": [
    [ "esp:GND.1", "pot_batt:GND", "black", [] ],
    [ "esp:GND.1", "pot_current:GND", "black", [] ],
    [ "esp:GND.1", "lcd:GND", "black", [] ],
    [ "esp:GND.1", "relay_medium:GND", "black", [ "v20", "h-50" ] ],
    [ "esp:GND.1", "relay_low:GND", "black", [ "v20", "h50" ] ],
    [ "esp:GND.1", "led_high_priority:C", "black", [ "v-30", "h-50", "v-20" ] ],
    [ "esp:GND.1", "led_medium_priority:C", "black", [ "v40", "h-80", "v-20" ] ],
    [ "esp:GND.1", "led_low_priority:C", "black", [ "v40", "h110", "v-20" ] ],

    [ "esp:3V3", "pot_batt:VCC", "red", [] ],
