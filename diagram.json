    [ "esp:5V", "relay_low:VCC", "red", [ "v-20", "h60" ] ],

    [ "pot_batt:SIG", "esp:34", "blue", [] ],
    [ "pot_current:SIG", "esp:32", "orange", [] ],
    
    [ "esp:21", "lcd:SDA", "green", [] ],
    [ "esp:22", "lcd:SCL", "yellow", [] ],

    [ "esp:18", "relay_medium:IN", "blue", [ "v30", "h-90" ] ],
    [ "esp:18", "led_medium_priority:A", "yellow", [ "h-50", "v50", "h-100", "v-20"  ] ],
    
    [ "esp:19", "relay_low:IN", "purple", [ "v30", "h90" ] ],
    [ "esp:19", "led_low_priority:A", "blue", [ "h-50","v50", "h110", "v-20" ] ]
